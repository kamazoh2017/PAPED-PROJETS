# -----------------------------------------------------------------------------
# Local development (SQLite — rapide, pas besoin d'installer PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Railway staging / production (PostgreSQL — configurer dans Railway dashboard)
# -----------------------------------------------------------------------------
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=<valeur copiée depuis Railway → service PostgreSQL → Variables>
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=<URL publique Railway de l'environnement>
