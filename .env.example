# Database (Supabase PostgreSQL)
# Use the "Connection string" from Supabase project settings.
# For pooled connections (recommended for Vercel):
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-xx-xx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional direct connection (if needed by Prisma tools):
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Environment
NODE_ENV=development

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
